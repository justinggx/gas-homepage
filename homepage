let sceneTransitionBusy = false;

function playSceneTransition(){
  const existing = document.getElementById('gas-scene-overlay');
  if(existing) existing.remove();

  const vv = window.visualViewport;
  const viewLeft = (window.scrollX || window.pageXOffset || 0) + (vv?.offsetLeft || 0);
  const viewTop = (window.scrollY || window.pageYOffset || 0) + (vv?.offsetTop || 0);
  const viewWidth = vv?.width || window.innerWidth || document.documentElement.clientWidth || 0;
  const viewHeight = vv?.height || window.innerHeight || document.documentElement.clientHeight || 0;
  const centerX = viewLeft + viewWidth / 2;
  const centerY = viewTop + viewHeight / 2;

  const frameWidth = Math.min(viewWidth * (viewWidth < 560 ? 0.84 : 0.76), 720);
  const frameHeight = Math.min(frameWidth * 0.7, viewHeight * 0.5);
  const lensSize = Math.min(frameWidth * 0.31, viewWidth * 0.32, 210);
  const cornerOffset = Math.max(18, Math.min(frameWidth * 0.04, 28));
  const cornerSize = Math.max(52, Math.min(frameWidth * 0.1, 72));

  const overlay = document.createElement('div');
  overlay.id = 'gas-scene-overlay';
  overlay.setAttribute('aria-hidden', 'true');
  overlay.style.cssText = [
    'position:absolute',
    `left:${viewLeft}px`,
    `top:${viewTop}px`,
    `width:${viewWidth}px`,
    `height:${viewHeight}px`,
    'z-index:2147483647',
    'pointer-events:none',
    'background:rgba(4,6,9,0)',
    'opacity:1',
    'transition:none',
    'overflow:visible'
  ].join(';');

  const frame = document.createElement('div');
  frame.style.cssText = [
    'position:absolute',
    `left:${centerX}px`,
    `top:${centerY}px`,
    'transform:translate(-50%,-50%) scale(.94)',
    `width:${frameWidth}px`,
    `height:${frameHeight}px`,
    'border:2px solid rgba(242,246,252,.92)',
    'box-shadow:0 0 0 1px rgba(201,170,114,.45) inset, 0 0 30px rgba(0,0,0,.45)',
    'opacity:0'
  ].join(';');

  const lens = document.createElement('div');
  lens.style.cssText = [
    'position:absolute',
    'left:50%',
    'top:50%',
    'transform:translate(-50%,-50%) scale(.9)',
    `width:${lensSize}px`,
    `height:${lensSize}px`,
    'border-radius:999px',
    'border:3px solid rgba(242,246,252,.96)',
    'box-shadow:0 0 0 2px rgba(201,170,114,.5) inset, 0 0 24px rgba(201,170,114,.22)',
    'background:radial-gradient(circle at 36% 34%, rgba(255,255,255,.35), rgba(255,255,255,.08) 18%, rgba(7,11,16,.94) 56%, rgba(2,3,5,1) 100%)',
    'opacity:0'
  ].join(';');

  const makeCorner = (x, y) => {
    const el = document.createElement('div');
    el.style.cssText = [
      'position:absolute',
      `${x}:${cornerOffset}px`,
      `${y}:${cornerOffset}px`,
      `width:${cornerSize}px`,
      `height:${cornerSize}px`,
      'border-color:rgba(245,248,252,.98)',
      'border-style:solid',
      'opacity:0'
    ].join(';');
    el.style.borderWidth = y === 'top' ? '4px 0 0 4px' : '0 0 4px 4px';
    if(x === 'right') el.style.borderWidth = y === 'top' ? '4px 4px 0 0' : '0 4px 4px 0';
    return el;
  };

  const tl = makeCorner('left', 'top');
  const tr = makeCorner('right', 'top');
  const bl = makeCorner('left', 'bottom');
  const br = makeCorner('right', 'bottom');

  const line = document.createElement('div');
  line.style.cssText = [
    'position:absolute',
    'left:10%',
    'right:10%',
    'top:50%',
    'height:3px',
    'background:linear-gradient(90deg, transparent, rgba(255,255,255,.98), rgba(201,170,114,1), transparent)',
    'box-shadow:0 0 18px rgba(255,255,255,.22)',
    'opacity:0',
    'transform:translateY(-50%) scaleX(.12)'
  ].join(';');

  const badgeFont = viewWidth < 560 ? '11px' : '12px';
  const badgePad = viewWidth < 560 ? '7px 10px' : '8px 12px';
  const badgeTop = viewWidth < 560 ? '16px' : '20px';
  const badgeSide = viewWidth < 560 ? '16px' : '24px';

  const rec = document.createElement('div');
  rec.style.cssText = [
    'position:absolute',
    `left:${badgeSide}`,
    `top:${badgeTop}`,
    `padding:${badgePad}`,
    'border:1px solid rgba(242,246,252,.22)',
    'background:rgba(8,10,14,.76)',
    'color:#f4efe7',
    `font-size:${badgeFont}`,
    'letter-spacing:.22em',
    'text-transform:uppercase',
    'opacity:0'
  ].join(';');
  rec.textContent = '● visée';

  const cap = document.createElement('div');
  cap.style.cssText = [
    'position:absolute',
    `right:${badgeSide}`,
    `top:${badgeTop}`,
    `padding:${badgePad}`,
    'border:1px solid rgba(242,246,252,.22)',
    'background:rgba(8,10,14,.76)',
    'color:#f4efe7',
    `font-size:${badgeFont}`,
    'letter-spacing:.22em',
    'text-transform:uppercase',
    'opacity:0'
  ].join(';');
  cap.textContent = 'capture';

  const copy = document.createElement('div');
  copy.style.cssText = [
    'position:absolute',
    'left:50%',
    'bottom:-62px',
    'transform:translateX(-50%) translateY(10px)',
    'text-align:center',
    'opacity:0',
    'color:#f4efe7',
    'width:max-content',
    'max-width:88vw'
  ].join(';');
  copy.innerHTML = `<div style="font-family:Cormorant Garamond,serif;font-size:${viewWidth < 560 ? '22px' : 'clamp(28px,3vw,38px)'};letter-spacing:.16em;text-transform:uppercase;">Ne bougez pas.</div><div style="margin-top:10px;font-family:Noto Serif SC,serif;font-size:${viewWidth < 560 ? '12px' : '13px'};letter-spacing:.28em;color:rgba(232,238,246,.82)">别动。</div>`;

  const flash = document.createElement('div');
  flash.style.cssText = [
    'position:absolute',
    'inset:0',
    'background:rgba(255,248,240,0)',
    'opacity:0'
  ].join(';');

  frame.append(tl,tr,bl,br,rec,cap,line,lens,copy);
  overlay.append(frame, flash);
  document.body.appendChild(overlay);

  const setStyles = (el, styles) => Object.assign(el.style, styles);

  return new Promise(resolve => {
    requestAnimationFrame(() => {
      setStyles(overlay, { background: 'rgba(4,6,9,0.82)' });
      setStyles(frame, { opacity: '1', transform: 'translate(-50%,-50%) scale(1)', transition: 'opacity .18s ease, transform .18s ease' });
      setStyles(lens, { opacity: '1', transform: 'translate(-50%,-50%) scale(1)', transition: 'opacity .22s ease, transform .22s ease' });
    });

    setTimeout(() => {
      [tl,tr,bl,br,rec,cap].forEach(el => setStyles(el, { opacity: '1', transition: 'opacity .12s ease' }));
      setStyles(copy, { opacity: '1', transform: 'translateX(-50%) translateY(0)', transition: 'opacity .16s ease, transform .16s ease' });
    }, 140);

    setTimeout(() => {
      setStyles(line, { opacity: '1', transform: 'translateY(-50%) scaleX(1)', transition: 'opacity .16s ease, transform .2s ease' });
    }, 240);

    setTimeout(() => {
      setStyles(line, { opacity: '0', transition: 'opacity .14s ease' });
    }, 520);

    setTimeout(() => {
      setStyles(flash, { opacity: '1', background: 'rgba(255,248,240,0.96)', transition: 'opacity .08s ease' });
    }, 860);

    setTimeout(() => {
      setStyles(flash, { opacity: '0', transition: 'opacity .18s ease' });
      setStyles(overlay, { opacity: '0', transition: 'opacity .18s ease' });
    }, 980);

    setTimeout(() => {
      overlay.remove();
      resolve();
    }, 1220);
  });
}

async function jmp(i, btn){
