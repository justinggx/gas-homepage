```html
<!-- v3.2.4 -->
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Gaspard de Valois · Dossier Archive</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Noto+Serif+SC:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#07080a;
  --bg-2:#0b0d10;
  --panel:#0e1117;
  --panel-2:#13181f;
  --panel-3:#181f28;
  --line:rgba(200,210,225,.10);
  --line-mid:rgba(200,210,225,.18);
  --line-strong:rgba(200,210,225,.28);
  --text:#edf1f8;
  --text-2:#bcc8d8;
  --text-3:#6e7f93;
  --silver:#d4dce8;
  --silver-2:#9aaabb;
  --gold:#c9aa72;
  --gold-soft:rgba(201,170,114,.12);
  --danger:#a76565;
  --shadow:0 32px 80px rgba(0,0,0,.6);
  --max:1440px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;height:100%;overflow-x:hidden;}
body{
  color:var(--text);
  font-family:"Inter",sans-serif;
  background:#07080a;
  min-height:100%;
  overflow-x:hidden;
  overflow-y:auto;
  -webkit-overflow-scrolling:touch;
  overscroll-behavior-y:auto;
  touch-action:pan-y;
  line-height:1;
}
img{display:block;max-width:100%}
button{font:inherit;cursor:pointer}

/* ─── GRAIN OVERLAY ─── */
body::after{
  content:"";
  position:fixed;inset:0;
  pointer-events:none;z-index:9999;
  opacity:.025;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size:200px;
}

/* ─── HERO ─── */
.hero{
  position:relative;
  width:100%;
  min-height:100vh;
  display:flex;
  flex-direction:column;
}

/* full-bleed photo */
.hero-photo{
  position:absolute;inset:0;
  background:
    url('https://i.postimg.cc/TYR9xMDc/expansion-20260413215109088.png')
    center 18% / cover no-repeat;
  transform-origin:center top;
}
/* cinematic colour grade */
.hero-photo::after{
  content:"";
  position:absolute;inset:0;
  background:
    linear-gradient(to right,  rgba(4,5,7,.82) 0%, rgba(4,5,7,.46) 42%, rgba(4,5,7,.20) 68%, rgba(4,5,7,.55) 100%),
    linear-gradient(to bottom, rgba(4,5,7,.12) 0%, rgba(4,5,7,.05) 38%, rgba(4,5,7,.72) 78%, rgba(4,5,7,.97) 100%);
  mix-blend-mode:multiply;
}
/* subtle vignette */
.hero-photo::before{
  content:"";
  position:absolute;inset:0;
  background:radial-gradient(ellipse at 50% 0%, transparent 40%, rgba(4,5,7,.55) 100%);
}

/* top rule */
.hero-rule{
  position:relative;z-index:2;
  padding:28px 48px 0;
  display:flex;
  align-items:center;
  justify-content:space-between;
}
.rule-left{
  display:flex;align-items:center;gap:12px;
  color:var(--text-3);
  font-size:.68rem;
  letter-spacing:.28em;
  text-transform:uppercase;
}
.rule-dot{
  width:6px;height:6px;border-radius:50%;
  background:var(--gold);
  box-shadow:0 0 8px rgba(201,170,114,.5);
}
.rule-right{
  color:var(--text-3);
  font-size:.68rem;
  letter-spacing:.22em;
  text-transform:uppercase;
}
.rule-divider{
  position:relative;z-index:2;
  margin:16px 48px 0;
  height:1px;
  background:linear-gradient(to right, rgba(201,170,114,.22), rgba(200,210,225,.10) 60%, transparent);
}

/* main copy block */
.hero-body{
  position:relative;z-index:2;
  flex:1;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  padding:0 48px 52px;
}

.hero-eyebrow{
  display:flex;align-items:center;gap:16px;
  margin-bottom:20px;
}
.eyebrow-line{
  width:36px;height:1px;
  background:var(--gold);
  opacity:.7;
}
.eyebrow-text{
  color:var(--gold);
  font-size:.7rem;
  font-weight:500;
  letter-spacing:.34em;
  text-transform:uppercase;
}

.hero-name{
  font-family:"Cormorant Garamond",serif;
  font-size:clamp(4rem,8.5vw,8.2rem);
  font-weight:700;
  line-height:.88;
  letter-spacing:.035em;
  text-transform:uppercase;
  color:#f4f7fc;
  text-shadow:0 4px 40px rgba(0,0,0,.5);
}
.hero-name-cn{
  display:block;
  margin-top:14px;
  font-family:"Noto Serif SC",serif;
  font-size:clamp(.9rem,1.6vw,1.2rem);
  font-weight:300;
  letter-spacing:.5em;
  color:var(--silver-2);
  text-shadow:none;
}

/* horizontal metadata strip */
.hero-meta{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:0;
  margin-top:28px;
  border-top:1px solid rgba(200,210,225,.10);
  border-bottom:1px solid rgba(200,210,225,.10);
  padding:0;
  align-items:stretch;
}
.meta-cell{
  padding:12px 22px;
  border-right:1px solid rgba(200,210,225,.12);
  border-bottom:1px solid rgba(200,210,225,.10);
  min-width:0;
}
.meta-cell:nth-child(3n){border-right:none}
.meta-cell:nth-child(n+4){border-bottom:none}
.meta-k{
  font-size:.6rem;
  letter-spacing:.22em;
  text-transform:uppercase;
  color:var(--text-3);
  margin-bottom:5px;
}
.meta-v{
  font-family:"Cormorant Garamond",serif;
  font-size:.98rem;
  color:var(--silver);
  letter-spacing:.04em;
  word-break:keep-all;
  overflow-wrap:anywhere;
}

/* desc block */
.hero-desc-row{
  display:grid;
  grid-template-columns:minmax(0,1.1fr) minmax(0,.7fr);
  gap:40px;
  margin-top:26px;
  align-items:end;
}
.hero-desc{
  font-family:"Noto Serif SC",serif;
  font-size:.95rem;
  line-height:2;
  color:var(--text-2);
  text-shadow:0 1px 8px rgba(0,0,0,.9);
}
.hero-tags{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  justify-content:flex-end;
}
.hero-tag{
  padding:7px 14px;
  border-radius:3px;
  border:1px solid rgba(200,210,225,.12);
  background:rgba(255,255,255,.04);
  color:var(--text-2);
  font-size:.76rem;
  letter-spacing:.06em;
  backdrop-filter:blur(8px);
}

/* scroll cue */
.hero-scroll{
  position:absolute;
  bottom:24px;right:48px;
  z-index:2;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:8px;
  color:var(--text-3);
  font-size:.6rem;
  letter-spacing:.28em;
  text-transform:uppercase;
}
.scroll-track{
  width:1px;height:42px;
  background:linear-gradient(to bottom, var(--gold), transparent);
  opacity:.5;
}

/* ─── PAGE WRAPPER ─── */
.page{
  width:min(var(--max), calc(100% - 28px));
  margin:0 auto;
  position:relative;z-index:1;
}

/* ─── SECTION HEADER ─── */
.sec-header{
  display:flex;
  align-items:baseline;
  gap:18px;
  margin-bottom:24px;
  padding-bottom:14px;
  border-bottom:1px solid var(--line);
}
.sec-header h2{
  font-family:"Cormorant Garamond",serif;
  font-size:1.7rem;
  font-weight:600;
  letter-spacing:.04em;
  color:var(--silver);
}
.sec-en{
  font-size:.68rem;
  letter-spacing:.22em;
  text-transform:uppercase;
  color:var(--text-3);
}

/* ─── INTEL BAND (replaces ribbon) ─── */
.intel-band{
  margin:22px 0 0;
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:0;
  border:1px solid var(--line);
  border-radius:4px;
  overflow:hidden;
}
.intel-cell{
  padding:24px 26px 22px;
  border-right:1px solid var(--line);
  background:var(--panel);
  position:relative;
}
.intel-cell:last-child{border-right:none}
.intel-cell::before{
  content:"";
  position:absolute;
  top:0;left:0;right:0;
  height:3px;
  background:linear-gradient(to right, var(--gold), transparent);
  opacity:.4;
}
.intel-num{
  font-family:"Cormorant Garamond",serif;
  font-size:2.2rem;
  font-weight:600;
  color:var(--gold);
  opacity:.35;
  line-height:1;
  margin-bottom:10px;
}
.intel-title{
  font-size:.7rem;
  font-weight:600;
  letter-spacing:.22em;
  text-transform:uppercase;
  color:var(--silver-2);
  margin-bottom:14px;
}
.intel-body{
  color:var(--text-2);
  font-size:.86rem;
  line-height:1.85;
}
.intel-body p{margin-bottom:6px}
.intel-body ul{padding-left:1.1em}
.intel-body li{margin-bottom:6px}
.perm-row{
  display:flex;align-items:flex-start;gap:10px;
  margin-bottom:8px;
}
.perm-badge{
  flex-shrink:0;
  width:18px;height:18px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:.62rem;margin-top:1px;
}
.perm-badge.allow{color:#8cc195;border:1px solid rgba(140,193,149,.3);background:rgba(140,193,149,.08)}
.perm-badge.deny{color:#d19090;border:1px solid rgba(209,144,144,.3);background:rgba(209,144,144,.08)}
.perm-badge.info{color:var(--text-3);border:1px solid var(--line);background:rgba(255,255,255,.04)}

/* ─── ARCHIVE SECTION ─── */
.archive{
  margin:22px 0 0;
}
.archive-nav{
  border:1px solid var(--line);
  border-radius:4px;
  overflow:hidden;
  background:var(--panel);
}
.archive-nav-head{
  padding:18px 22px 14px;
  border-bottom:1px solid var(--line);
}
.archive-nav-head h2{
  font-family:"Cormorant Garamond",serif;
  font-size:1.5rem;font-weight:600;
  color:var(--silver);letter-spacing:.04em;
}
.archive-nav-head p{
  margin-top:6px;
  color:var(--text-3);font-size:.78rem;line-height:1.7;
}
.nav-stack{
  display:grid;
  grid-template-columns:repeat(5,1fr);
}
.arc-btn{
  text-align:left;width:100%;
  padding:18px 20px 16px;
  border:none;
  border-right:1px solid var(--line);
  background:transparent;
  color:var(--text-2);
  transition:.2s ease;
  position:relative;
}
.arc-btn:last-child{border-right:none}
.arc-btn::after{
  content:"";
  position:absolute;left:0;right:0;bottom:0;
  height:3px;background:var(--gold);
  opacity:0;transition:.2s;
}
.arc-btn:hover{background:rgba(255,255,255,.03)}
.arc-btn.active{background:rgba(201,170,114,.06)}
.arc-btn.active::after{opacity:1}
.arc-btn small{
  display:block;margin-bottom:6px;
  font-size:.62rem;letter-spacing:.2em;
  text-transform:uppercase;color:var(--text-3);
}
.arc-btn.active small{color:var(--gold);opacity:.8}
.arc-btn strong{
  display:block;
  font-family:"Cormorant Garamond",serif;
  font-size:1.22rem;font-weight:600;
  color:var(--silver);letter-spacing:.02em;
  margin-bottom:4px;
}
.arc-btn span{
  display:block;margin-top:4px;
  font-size:.76rem;color:var(--text-3);line-height:1.5;
}
.arc-suben{
  display:none;
  margin-top:4px;
  font-style:normal;
  color:var(--silver-2);
  font-size:.62rem;
  letter-spacing:.18em;
  text-transform:uppercase;
}
.arc-count{
  display:inline-block;margin-top:8px;
  padding:4px 10px;
  border-radius:3px;
  border:1px solid var(--line);
  background:rgba(255,255,255,.03);
  color:var(--text-3);
  font-size:.68rem;letter-spacing:.08em;
}
.arc-btn.active .arc-count{
  border-color:rgba(201,170,114,.22);
  background:rgba(201,170,114,.08);
  color:var(--gold);
}

/* drawer that expands below nav */
.archive-drawer{
  overflow:hidden;
  max-height:0;
  transition:max-height .38s cubic-bezier(.4,0,.2,1);
}
.archive-drawer.open{
  max-height:9999px;
}
.archive-drawer-inner{
  padding-top:14px;
  display:grid;
  gap:16px;
}

.archive-main{display:grid;gap:16px}

/* panels */
.arc-panel{display:none;gap:14px}
.arc-panel.active{display:grid}

.arc-head{
  border:1px solid var(--line);
  border-radius:4px;
  background:var(--panel);
  padding:22px 24px 20px;
  position:relative;overflow:hidden;
}
.arc-head::after{
  content:"";
  position:absolute;bottom:0;left:0;right:0;height:1px;
  background:linear-gradient(to right, var(--gold), transparent);
  opacity:.2;
}
.arc-head-top{
  display:flex;gap:14px;align-items:baseline;flex-wrap:wrap;
}
.arc-head-top h3{
  font-family:"Cormorant Garamond",serif;
  font-size:1.9rem;font-weight:600;
  letter-spacing:.04em;color:var(--silver);
}
.arc-head-top .en{
  color:var(--text-3);font-size:.68rem;
  letter-spacing:.22em;text-transform:uppercase;
}
.arc-head-meta{margin:12px 0 0;display:flex;gap:8px;flex-wrap:wrap}
.arc-chip{
  padding:5px 10px;border-radius:3px;
  border:1px solid var(--line);
  background:rgba(255,255,255,.03);
  color:var(--text-2);font-size:.72rem;letter-spacing:.04em;
}
.arc-head p{
  margin:12px 0 0;max-width:860px;
  color:var(--text-2);font-size:.88rem;line-height:1.85;
}

/* ─── DOSSIER CARDS ─── */
.dossier-list{display:grid;gap:12px}
.dossier{
  border:1px solid var(--line);
  border-radius:4px;
  background:var(--panel);
  overflow:hidden;
  transition:border-color .22s;
}

.dossier-top{
  display:grid;
  grid-template-columns:280px minmax(0,1fr);
  gap:0;
}
.dossier-cover{
  position:relative;
  min-height:200px;overflow:hidden;
}
.dossier-cover img{
  width:100%;height:100%;object-fit:cover;
  filter:brightness(.85) saturate(.88);
  transition:transform .5s cubic-bezier(.16,1,.3,1),filter .3s;
}
.dossier-cover::after{
  content:"";position:absolute;inset:0;
  background:linear-gradient(90deg, rgba(7,8,10,0) 50%, rgba(7,8,10,.55) 100%),
             linear-gradient(0deg, rgba(7,8,10,.75) 0%, transparent 45%);
}
.case-no{
  position:absolute;top:12px;left:12px;z-index:2;
  padding:5px 10px;
  border-radius:2px;
  border:1px solid rgba(201,170,114,.25);
  background:rgba(7,8,10,.55);
  color:var(--gold);
  font-size:.62rem;letter-spacing:.22em;
  text-transform:uppercase;backdrop-filter:blur(8px);
}
.cover-caption{
  position:absolute;left:12px;right:12px;bottom:12px;z-index:2;
}
.cover-caption small{
  display:block;margin-bottom:4px;
  color:var(--silver-2);font-size:.62rem;
  letter-spacing:.2em;text-transform:uppercase;
}
.cover-caption strong{
  display:block;
  font-family:"Cormorant Garamond",serif;
  font-size:1.18rem;font-weight:600;
  line-height:1.2;color:#f4f7fc;
}

.dossier-body{
  padding:18px 20px 16px;
  display:flex;flex-direction:column;
  border-left:1px solid var(--line);
}
.dossier-meta{
  display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px;
}
.meta-pill{
  padding:4px 9px;border-radius:2px;
  border:1px solid var(--line);
  background:rgba(255,255,255,.03);
  color:var(--text-3);font-size:.68rem;letter-spacing:.05em;
}
.dossier-summary{
  font-family:"Noto Serif SC",serif;
  font-size:.88rem;line-height:1.95;color:var(--text-2);
  flex:1;
}
.dossier-actions{
  display:flex;align-items:center;
  justify-content:space-between;gap:10px;
  margin-top:14px;padding-top:12px;
  border-top:1px solid var(--line);
  flex-wrap:wrap;
}

/* ─── DESKTOP HOVER LOCK ─── */
@media (min-width: 769px){
  .dossier,
  .dossier:hover,
  .dossier:focus,
  .dossier:focus-within,
  .dossier:active{
    transform:none !important;
    scale:1 !important;
  }

  .dossier-cover img,
  .dossier:hover .dossier-cover img,
  .dossier:focus .dossier-cover img,
  .dossier:focus-within .dossier-cover img,
  .dossier:active .dossier-cover img{
    transform:none !important;
    scale:1 !important;
    filter:brightness(.85) saturate(.88) !important;
  }
}
.hint{color:var(--text-3);font-size:.72rem;letter-spacing:.04em;line-height:1.6}
.hint-alert{
  display:inline;
  padding:0;
  border:none;
  background:none;
  color:#e7c27d;
  font-weight:600;
  letter-spacing:.06em;
  text-shadow:0 0 8px rgba(201,170,114,.22);
  animation:hintPulse 1.25s ease-in-out infinite;
}
@keyframes hintPulse{
  0%,100%{
    opacity:1;
    color:#e7c27d;
    text-shadow:0 0 6px rgba(201,170,114,.16);
  }
  50%{
    opacity:.38;
    color:#ffd78f;
    text-shadow:0 0 14px rgba(255,215,143,.34), 0 0 22px rgba(255,215,143,.18);
  }
}
.action-row{display:flex;gap:8px;flex-wrap:wrap}
.action-row.action-right{width:100%;justify-content:flex-end}

.btn{
  padding:8px 16px;
  border-radius:999px;
  border:1px solid rgba(214,223,238,.28);
  background:linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.02));
  color:#e7edf7;
  font-size:.76rem;letter-spacing:.06em;
  transition:.2s;
}
.btn.is-busy{
  opacity:.72;
}
.btn:hover{
  border-color:rgba(214,223,238,.3);
  background:linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.03));
  box-shadow:0 10px 24px rgba(0,0,0,.22);
}
.btn-ghost{
  padding:8px 16px;
  border-radius:2px;
  border:1px solid var(--line);
  background:transparent;
  color:var(--text-2);
  font-size:.76rem;letter-spacing:.06em;
  transition:.2s;
}
.btn-ghost:hover{background:rgba(255,255,255,.04);border-color:var(--line-mid)}

.hidden-grid{
  display:grid;grid-template-columns:1.1fr .9fr;gap:14px;
}
.hidden-box{
  border:1px solid var(--line);border-radius:3px;
  padding:14px 16px;background:rgba(255,255,255,.02);
}
.hidden-box h4{
  margin-bottom:8px;
  font-size:.66rem;font-weight:600;letter-spacing:.2em;
  text-transform:uppercase;color:var(--silver-2);
}
.hidden-box p,.hidden-box li{
  margin-bottom:6px;font-size:.84rem;line-height:1.82;color:var(--text-2);
}
.hidden-box ul{margin:0;padding-left:1.1em}

/* ─── CHANGELOG ─── */
.changelog{
  margin:16px 0 0;
  border:1px solid var(--line);border-radius:4px;
  background:var(--panel);overflow:hidden;
}
.changelog-head{
  padding:16px 22px 14px;
  border-bottom:1px solid var(--line);
  display:flex;align-items:baseline;gap:14px;
}
.changelog-head h3{
  font-family:"Cormorant Garamond",serif;
  font-size:1.5rem;font-weight:600;color:var(--silver);
}
.changelog-row{
  display:grid;grid-template-columns:110px 1fr;gap:14px;
  padding:12px 22px;border-bottom:1px solid var(--line);
}
.changelog-row:last-child{border-bottom:none}
.changelog-row time{color:var(--silver-2);font-size:.76rem;letter-spacing:.12em}
.changelog-row p{color:var(--text-2);font-size:.85rem;line-height:1.8}

/* ─── FOOTER ─── */
.footer{
  margin:16px 0 0;
  padding:20px 0 40px;
  display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;
  color:var(--text-3);font-size:.68rem;letter-spacing:.16em;text-transform:uppercase;
  border-top:1px solid var(--line);
}

/* ─── RESPONSIVE ─── */
@media(max-width:1100px){
  .intel-band{grid-template-columns:1fr}
  .intel-cell{border-right:none;border-bottom:1px solid var(--line)}
  .intel-cell:last-child{border-bottom:none}
}
@media(max-width:900px){
  .hero-rule,.rule-divider,.hero-body{padding-left:28px;padding-right:28px}
  .hero-photo{background-position:58% 18%}
  .hero-desc-row{grid-template-columns:1fr;gap:18px}
  .hero-tags{justify-content:flex-start}
}
