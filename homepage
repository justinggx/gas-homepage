/* ─── SCENE TRANSITION / CAMERA FLASH ─── */
.scene-transition{
  position:fixed;
  inset:0;
  z-index:10020;
  pointer-events:none;
  opacity:0;
  visibility:hidden;
  transition:opacity .18s ease, visibility .18s ease;
}
.scene-transition.active{
  opacity:1;
  visibility:visible;
}
.scene-transition::before{
  content:"";
  position:absolute;
  inset:0;
  background:rgba(5,7,10,.86);
  backdrop-filter:blur(2px);
}
.scene-transition.playing .transition-stage{opacity:1}
.scene-transition.playing .camera-rig{animation:camRigEnter .9s cubic-bezier(.22,.8,.18,1) forwards}
.scene-transition.playing .camera-lens{animation:camLensPulse .9s cubic-bezier(.22,.8,.18,1) forwards}
.scene-transition.playing .focus-bracket{animation:focusBracketLock .44s cubic-bezier(.24,.78,.22,1) forwards}
.scene-transition.playing .focus-bracket.tl{animation-delay:.12s}
.scene-transition.playing .focus-bracket.tr{animation-delay:.18s}
.scene-transition.playing .focus-bracket.bl{animation-delay:.24s}
.scene-transition.playing .focus-bracket.br{animation-delay:.3s}
.scene-transition.playing .focus-line{animation:focusSweep .56s ease-out .2s forwards}
.scene-transition.playing .transition-copy{animation:copyReveal .62s ease-out .34s forwards}
.scene-transition.playing .camera-glint{animation:glintSweep .6s ease-out .28s forwards}
.scene-transition.playing .flash-layer{animation:flashBurst .42s cubic-bezier(.16,.84,.2,1) .95s forwards}
.scene-transition.playing .film-grain{animation:grainBlink .34s steps(2,end) .98s forwards}
.scene-transition.playing .rec-badge{animation:badgeReveal .3s ease-out .08s forwards}
.scene-transition.playing .shutter-label{animation:badgeReveal .3s ease-out .18s forwards}
.transition-stage{
  position:absolute;
  inset:0;
  display:flex;
  align-items:center;
  justify-content:center;
  opacity:0;
}
.camera-rig{
  position:relative;
  width:min(84vw, 720px);
  max-height:70vh;
  aspect-ratio:1 / .7;
  opacity:0;
  transform:scale(.9) translateY(14px);
}
.camera-shell{
  position:absolute;
  inset:0;
  border:1px solid rgba(212,220,232,.12);
  border-radius:22px;
  background:linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.015));
  box-shadow:0 24px 80px rgba(0,0,0,.46), inset 0 0 0 1px rgba(201,170,114,.06);
}
.rec-badge,
.shutter-label{
  position:absolute;
  top:18px;
  padding:8px 12px;
  border:1px solid rgba(212,220,232,.14);
  background:rgba(7,9,12,.72);
  color:#f3efe7;
  font-size:.68rem;
  letter-spacing:.22em;
  text-transform:uppercase;
  opacity:0;
}
.rec-badge{left:18px}
.shutter-label{right:18px}
.rec-dot{
  display:inline-block;
  width:8px;height:8px;border-radius:50%;
  margin-right:8px;
  background:#d9b37a;
  box-shadow:0 0 12px rgba(217,179,122,.75);
}
.camera-vignette{
  position:absolute;
  inset:-10%;
  border-radius:999px;
  background:radial-gradient(circle, rgba(255,255,255,.05) 0%, rgba(255,255,255,0) 64%);
  filter:blur(20px);
  opacity:.8;
}
.camera-lens{
  position:absolute;
  left:50%;
  top:50%;
  width:min(34vw, 240px);
  aspect-ratio:1;
  transform:translate(-50%, -50%) scale(.88);
  border-radius:50%;
  border:2px solid rgba(214,223,238,.34);
  background:radial-gradient(circle at 35% 35%, rgba(255,255,255,.3), rgba(255,255,255,.08) 18%, rgba(10,14,18,.92) 58%, rgba(2,4,6,1) 100%);
  box-shadow:0 0 0 2px rgba(201,170,114,.16) inset, 0 0 0 18px rgba(255,255,255,.02) inset, 0 0 42px rgba(201,170,114,.14), 0 28px 90px rgba(0,0,0,.6);
}
.camera-lens::before,
.camera-lens::after{
  content:"";
  position:absolute;
  border-radius:50%;
}
.camera-lens::before{
  inset:14%;
  border:2px solid rgba(212,220,232,.24);
}
.camera-lens::after{
  inset:30%;
  background:radial-gradient(circle at 42% 38%, rgba(255,255,255,.22), rgba(255,255,255,0) 44%);
}
.camera-glint{
  position:absolute;
  top:16%;
  left:20%;
  width:58%;
  height:3px;
  border-radius:999px;
  background:linear-gradient(90deg, transparent, rgba(255,255,255,.98), rgba(255,238,212,.78), transparent);
  opacity:0;
  transform:translateX(-22%) rotate(-11deg);
}
.focus-bracket{
  position:absolute;
  width:min(20vw, 132px);
  height:min(20vw, 132px);
  opacity:0;
  transform:scale(.78);
}
.focus-bracket::before,
.focus-bracket::after{
  content:"";
  position:absolute;
  background:linear-gradient(90deg, rgba(240,244,252,1), rgba(201,170,114,.95));
  box-shadow:0 0 16px rgba(255,245,230,.16);
}
.focus-bracket::before{height:3px;width:58px}
.focus-bracket::after{width:3px;height:58px}
.focus-bracket.tl{top:9%;left:7%}
.focus-bracket.tl::before,.focus-bracket.tl::after{top:0;left:0}
.focus-bracket.tr{top:9%;right:7%}
.focus-bracket.tr::before,.focus-bracket.tr::after{top:0;right:0}
.focus-bracket.bl{bottom:9%;left:7%}
.focus-bracket.bl::before,.focus-bracket.bl::after{bottom:0;left:0}
.focus-bracket.br{bottom:9%;right:7%}
.focus-bracket.br::before,.focus-bracket.br::after{bottom:0;right:0}
.focus-line{
  position:absolute;
  left:10%;
  right:10%;
  top:50%;
  height:2px;
  background:linear-gradient(90deg, transparent, rgba(245,242,236,.96), rgba(201,170,114,1), transparent);
  box-shadow:0 0 18px rgba(255,246,233,.34);
  opacity:0;
  transform:scaleX(.16);
}
.transition-copy{
  position:absolute;
  left:50%;
  bottom:-64px;
  transform:translateX(-50%) translateY(12px);
  text-align:center;
  opacity:0;
}
.transition-copy .fr{
  display:block;
  font-family:"Cormorant Garamond",serif;
  font-size:clamp(1.55rem,2.9vw,2.2rem);
  letter-spacing:.18em;
  text-transform:uppercase;
  color:#f4efe7;
  text-shadow:0 0 24px rgba(0,0,0,.4);
}
.transition-copy .cn{
  display:block;
  margin-top:10px;
  font-family:"Noto Serif SC",serif;
  font-size:.82rem;
  letter-spacing:.28em;
  color:rgba(232,238,246,.78);
}
.flash-layer,
.film-grain{
  position:absolute;
  inset:0;
  opacity:0;
  pointer-events:none;
}
.flash-layer{
  background:radial-gradient(circle at 50% 45%, rgba(255,251,246,.98), rgba(255,248,239,.94) 20%, rgba(255,245,234,.62) 42%, rgba(255,241,225,0) 72%), linear-gradient(180deg, rgba(255,252,248,.92), rgba(255,248,240,.68));
  mix-blend-mode:screen;
}
.film-grain{
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='1.15' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)' opacity='.9'/%3E%3C/svg%3E");
  background-size:170px;
  mix-blend-mode:soft-light;
}
@keyframes camRigEnter{0%{opacity:0;transform:scale(.9) translateY(14px)}30%{opacity:1}100%{opacity:1;transform:scale(1) translateY(0)}}
@keyframes camLensPulse{0%{transform:translate(-50%, -50%) scale(.86)}48%{transform:translate(-50%, -50%) scale(1.03)}100%{transform:translate(-50%, -50%) scale(.99)}}
@keyframes focusBracketLock{0%{opacity:0;transform:scale(.78)}100%{opacity:1;transform:scale(1)}}
@keyframes focusSweep{0%{opacity:0;transform:scaleX(.16)}30%{opacity:1}100%{opacity:0;transform:scaleX(1)}}
@keyframes copyReveal{0%{opacity:0;transform:translateX(-50%) translateY(12px)}100%{opacity:1;transform:translateX(-50%) translateY(0)}}
@keyframes glintSweep{0%{opacity:0;transform:translateX(-22%) rotate(-11deg)}40%{opacity:1}100%{opacity:0;transform:translateX(20%) rotate(-11deg)}}
@keyframes flashBurst{0%{opacity:0}12%{opacity:1}46%{opacity:.96}100%{opacity:0}}
@keyframes grainBlink{0%{opacity:0}32%{opacity:.28}100%{opacity:0}}
@keyframes badgeReveal{0%{opacity:0;transform:translateY(-6px)}100%{opacity:1;transform:translateY(0)}}

@media (prefers-reduced-motion: reduce){
  .scene-transition,
  .scene-transition *{animation:none !important;transition:none !important}
  .scene-transition.playing .transition-stage,
  .scene-transition.playing .camera-rig,
  .scene-transition.playing .focus-bracket,
  .scene-transition.playing .transition-copy,
  .scene-transition.playing .rec-badge,
  .scene-transition.playing .shutter-label{opacity:1;transform:none}
  .scene-transition.playing .flash-layer{opacity:.92}
}

