<script>
const isTouchMobileLayout = () => window.innerWidth <= 768;

function toggleArc(name, btn){
  const drawer = document.getElementById('archive-drawer');
  const navStack = document.querySelector('.nav-stack');
  const isMobile = isTouchMobileLayout();
  const isActive = btn.classList.contains('active');

  document.querySelectorAll('.arc-btn').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.arc-panel').forEach(el=>el.classList.remove('active'));

  if(isActive){
    drawer.classList.remove('open');
    if(isMobile){
      navStack.insertAdjacentElement('afterend', drawer);
    }
    return;
  }

  btn.classList.add('active');
  const panel = document.querySelector(`[data-arc-panel="${name}"]`);
  if(panel) panel.classList.add('active');

  if(isMobile){
    btn.insertAdjacentElement('afterend', drawer);
  }else{
    navStack.insertAdjacentElement('afterend', drawer);
  }

  drawer.classList.add('open');
}

window.addEventListener('resize', ()=>{
  const drawer = document.getElementById('archive-drawer');
